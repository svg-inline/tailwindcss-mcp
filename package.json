{
  "name": "tailwindcss-mcp",
  "version": "2.0.0",
  "description": "MCP server for Tailwind CSS v4 — SQLite cache + GitHub SHA revalidation",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tailwindcss-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/copy-assets.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "crawl": "node dist/cli-crawl.js",
    "crawl:check": "node dist/cli-crawl.js check",
    "crawl:fix-sections": "node dist/cli-crawl.js fix-sections"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "sql.js": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
